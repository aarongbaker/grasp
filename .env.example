# App
APP_ENV=development
LOG_LEVEL=INFO

# Postgres (FastAPI / asyncpg)
DATABASE_URL=postgresql+asyncpg://grasp:grasp@localhost:5432/grasp
LANGGRAPH_CHECKPOINT_URL=postgresql://grasp:grasp@localhost:5432/grasp

# Postgres (Test)
TEST_DATABASE_URL=postgresql+asyncpg://grasp:grasp@localhost:5432/grasp_test
TEST_LANGGRAPH_CHECKPOINT_URL=postgresql://grasp:grasp@localhost:5432/grasp_test

# Auth
JWT_SECRET_KEY=change-me-generate-with-python-c-import-secrets-print-secrets-token_urlsafe-64

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# LLM
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...

# Pinecone
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=grasp-cookbooks
PINECONE_ENVIRONMENT=us-east-1-aws

# Pipeline
CELERY_TASK_TIMEOUT=600
CELERY_WORKER_CONCURRENCY=4
