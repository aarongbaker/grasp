# ── App ──────────────────────────────────────────────────────────────────────
# APP_ENV: "development" (default) or "production"
#   development keeps localhost defaults and allows the placeholder JWT secret
#   production enables strict JWT + CORS validation at startup
APP_ENV=development
LOG_LEVEL=INFO

# ── Auth ─────────────────────────────────────────────────────────────────────
# Optional in local development. REQUIRED in production.
# Generate a production secret with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-in-production
# These defaults are safe to keep unless you intentionally need different auth timings.
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# ── CORS ─────────────────────────────────────────────────────────────────────
# Leave unset for host-run local development.
# Default development origins: http://localhost:3000, http://localhost:8501, http://localhost:5173
# In production this MUST be a JSON array string, for example:
#   CORS_ALLOWED_ORIGINS=["https://grasp.pages.dev"]
# CORS_ALLOWED_ORIGINS=["https://grasp.pages.dev"]

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# FastAPI / SQLAlchemy uses asyncpg driver:
DATABASE_URL=postgresql+asyncpg://grasp:grasp@localhost:5432/grasp
# LangGraph checkpointer uses psycopg3 (sync) driver — same DB, different scheme:
LANGGRAPH_CHECKPOINT_URL=postgresql://grasp:grasp@localhost:5432/grasp

# ── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Set this to run the hosted planning pipeline locally.
# The API can boot without it, but session generation / planning will fail.
ANTHROPIC_API_KEY=sk-ant-...

# ── Pipeline Tuning ──────────────────────────────────────────────────────────
CELERY_TASK_TIMEOUT=600
# The checked-in worker contract is fixed at `--pool=solo --concurrency=1`.
# Do not raise this value unless the worker memory/correctness boundary is redesigned.
CELERY_WORKER_CONCURRENCY=1

# ── Frontend build env (Cloudflare Pages only; NOT used by local Vite dev) ──
# Set this in the Cloudflare Pages project, not in local `.env`:
#   VITE_API_URL=https://your-api.up.railway.app
# Rules:
#   - no trailing slash
#   - do not include /api/v1
#   - required only when frontend and API are on different origins

# ── Test-Only (not needed for normal local startup or production) ───────────
# TEST_DATABASE_URL=postgresql+asyncpg://grasp:grasp@localhost:5433/grasp_test
# TEST_LANGGRAPH_CHECKPOINT_URL=postgresql://grasp:grasp@localhost:5433/grasp_test
