# ── App ──────────────────────────────────────────────────────────────────────
# APP_ENV: "development" (default) or "production"
#   production triggers: JWT secret validation, CORS origin validation
APP_ENV=development
LOG_LEVEL=INFO

# ── Auth ─────────────────────────────────────────────────────────────────────
# REQUIRED in production. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-in-production

# ── CORS ─────────────────────────────────────────────────────────────────────
# JSON array of allowed origins. Production example:
#   CORS_ALLOWED_ORIGINS=["https://grasp.pages.dev"]
# Defaults to ["http://localhost:3000", "http://localhost:8501"] if unset.
# CORS_ALLOWED_ORIGINS=["https://grasp.pages.dev"]

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# FastAPI / SQLAlchemy uses asyncpg driver:
DATABASE_URL=postgresql+asyncpg://grasp:grasp@localhost:5432/grasp
# LangGraph checkpointer uses psycopg3 (sync) driver — same DB, different scheme:
LANGGRAPH_CHECKPOINT_URL=postgresql://grasp:grasp@localhost:5432/grasp

# ── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── LLM Providers ────────────────────────────────────────────────────────────
# REQUIRED — pipeline will not function without these
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...

# ── Pinecone (Vector Store) ──────────────────────────────────────────────────
# REQUIRED for RAG enrichment
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=grasp-cookbooks
PINECONE_ENVIRONMENT=us-east-1-aws

# ── Pipeline Tuning ──────────────────────────────────────────────────────────
CELERY_TASK_TIMEOUT=600
CELERY_WORKER_CONCURRENCY=4

# ── Test-Only (not needed for production) ────────────────────────────────────
# TEST_DATABASE_URL=postgresql+asyncpg://grasp:grasp@localhost:5432/grasp_test
# TEST_LANGGRAPH_CHECKPOINT_URL=postgresql://grasp:grasp@localhost:5432/grasp_test
