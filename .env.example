# App
APP_ENV=development
LOG_LEVEL=INFO

# Postgres (FastAPI / asyncpg)
DATABASE_URL=postgresql+asyncpg://grasp:grasp@localhost:5432/grasp
LANGGRAPH_CHECKPOINT_URL=postgresql://grasp:grasp@localhost:5432/grasp

# Postgres (Test)
TEST_DATABASE_URL=postgresql+asyncpg://grasp:grasp@localhost:5433/grasp_test
TEST_LANGGRAPH_CHECKPOINT_URL=postgresql://grasp:grasp@localhost:5433/grasp_test

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# LLM
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Pinecone
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=grasp-cookbooks
PINECONE_ENVIRONMENT=us-east-1-aws

# Pipeline
CELERY_TASK_TIMEOUT=600
CELERY_WORKER_CONCURRENCY=4